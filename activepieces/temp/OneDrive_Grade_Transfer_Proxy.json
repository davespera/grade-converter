            "sourceCode": {
              "code": "export const code = async (inputs) => {\n  // grades should be an array of {subject, origin_grade} objects\n  const response = await fetch('http://backend:8000/transfer/?format=xlsx', {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'x-api-key': process.env.FASTAPI_ACTIVEPIECES_API_KEY || '',\n    },\n    body: JSON.stringify({\n      scale_id: Number(inputs.scale_id),\n      grades: inputs.grades,\n    }),\n  });\n\n  const blob = await response.blob();\n  \n  // Convert blob to base64 for ActivePieces (if needed)\n  const arrayBuffer = await blob.arrayBuffer();\n  const base64 = Buffer.from(arrayBuffer).toString('base64');\n\n  return {\n    status: response.status,\n    file: base64,\n    contentType: response.headers.get('content-type'),\n  };\n};",
              "packageJson": "{}"
            },
