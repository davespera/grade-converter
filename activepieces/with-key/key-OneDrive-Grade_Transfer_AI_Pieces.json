                    "code": "export const code = async (inputs) => {\n  // Reduce the extracted grades to the distinct origin-grade strings the\n  // /scales/match endpoint expects.\n  const grades = Array.isArray(inputs.grades) ? inputs.grades : [];\n  const distinct = [...new Set(grades.map((g) => g.origin_grade).filter((v) => v != null))];\n  return { country: inputs.country || '', grades: distinct };\n};",
