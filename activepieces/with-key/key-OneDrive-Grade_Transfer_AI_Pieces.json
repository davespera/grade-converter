                      "sampleData": {},
                      "sourceCode": {
                        "code": "export const code = async (inputs) => {\n  // Decide, from the ranked /scales/match candidates, whether we can confidently\n  // pick a scale. If not, build a needs-review artifact instead of guessing.\n  const MIN_COVERAGE = 1.0;\n  const candidates = Array.isArray(inputs.candidates) ? inputs.candidates : [];\n  const grades = Array.isArray(inputs.grades) ? inputs.grades : [];\n\n  const rawName = inputs.file_name || 'transcript';\n  const base = rawName.replace(/\\.[^/.]+$/, '') || 'transcript';\n\n  const top = candidates[0];\n  const second = candidates[1];\n  let reason = null;\n  if (!top || top.coverage < MIN_COVERAGE) {\n    reason = top ? 'low_coverage' : 'no_candidates';\n  } else if (\n    second &&\n    second.coverage === top.coverage &&\n    second.scale_total_grades === top.scale_total_grades\n  ) {\n    reason = 'ambiguous';\n  }\n\n  if (reason) {\n    const review = {\n      status: 'NEEDS_REVIEW',\n      reason,\n      extracted: {\n        country: inputs.country || null,\n        grading_system: inputs.grading_system || null,\n        grade_type: inputs.grade_type || null,\n        grades,\n      },\n      candidates: candidates.slice(0, 5),\n      instructions:\n        'Pick the correct scale_id and re-run the transfer manually, or fix the country in the document and re-upload.',\n    };\n    return {\n      confident: false,\n      needsReview: true,\n      reason,\n      scale_id: null,\n      coveredGrades: [],\n      reviewFile: Buffer.from(JSON.stringify(review, null, 2)).toString('base64'),\n      fileName: `${base}-NEEDS-REVIEW.json`,\n    };\n  }\n\n  // Confident: transfer only the grades the matched scale actually covers.\n  const unmatched = new Set(top.unmatched_grades || []);\n  const coveredGrades = grades.filter((g) => !unmatched.has(g.origin_grade));\n  return {\n    confident: true,\n    needsReview: false,\n    reason: null,\n    scale_id: top.scale_id,\n    coveredGrades,\n    reviewFile: '',\n    fileName: `${base}-transfer.xlsx`,\n  };\n};",
                        "packageJson": "{}"
                      },
