{
  "name": "OneDrive JSON Processor Flow",
  "trigger": {
    "name": "new_file_in_folder",
    "type": "PIECE_TRIGGER",
    "settings": {
      "pieceName": "@activepieces/piece-microsoft-onedrive",
      "triggerName": "new_file",
      "input": {
        "folder": "/incoming"
      }
    }
  },
  "steps": [
    {
      "name": "Filter JSON Files",
      "type": "BRANCH",
      "settings": {
        "conditions": [
          {
            "operator": "TEXT_ENDS_WITH",
            "firstValue": "{{trigger.file.name}}",
            "secondValue": ".json"
          }
        ]
      }
    },
    {
      "name": "Get File Content",
      "type": "PIECE_ACTION",
      "settings": {
        "pieceName": "@activepieces/piece-microsoft-onedrive",
        "actionName": "get_file_content",
        "input": {
          "fileId": "{{trigger.file.id}}"
        }
      }
    },
    {
      "name": "Parse JSON",
      "type": "CODE",
      "settings": {
        "language": "javascript",
        "code": "const base64 = steps['Get File Content'].output;\nconst content = Buffer.from(base64, 'base64').toString('utf-8');\n\nconst parsed = JSON.parse(content);\n\nreturn {\n  parsedJson: parsed,\n  originalFileName: trigger.file.name\n};"
      }
    },
    {
      "name": "Send to Backend",
      "type": "PIECE_ACTION",
      "settings": {
        "pieceName": "@activepieces/piece-http",
        "actionName": "request",
        "input": {
          "method": "POST",
          "url": "https://your-backend.com/process",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "fileName": "{{steps['Parse JSON'].output.originalFileName}}",
            "data": "{{steps['Parse JSON'].output.parsedJson}}"
          }
        }
      }
    },
    {
      "name": "Prepare Output JSON",
      "type": "CODE",
      "settings": {
        "language": "javascript",
        "code": "const response = steps['Send to Backend'].output.body;\n\nreturn {\n  outputFileContent: JSON.stringify(response, null, 2)\n};"
      }
    },
    {
      "name": "Upload Processed File",
      "type": "PIECE_ACTION",
      "settings": {
        "pieceName": "@activepieces/piece-microsoft-onedrive",
        "actionName": "upload_file",
        "input": {
          "folder": "/processed",
          "fileName": "processed_{{steps['Parse JSON'].output.originalFileName}}",
          "fileContent": "{{steps['Prepare Output JSON'].output.outputFileContent}}"
        }
      }
    },
    {
      "name": "Move Original File",
      "type": "PIECE_ACTION",
      "settings": {
        "pieceName": "@activepieces/piece-microsoft-onedrive",
        "actionName": "move_file",
        "input": {
          "fileId": "{{trigger.file.id}}",
          "destinationFolder": "/archive"
        }
      }
    }
  ]
}
